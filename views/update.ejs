<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/update.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <%- include("partials/head.ejs") %>
        <section class="note-form-container">

            <form action="/show/<%= note._id %>?_method=PATCH" method="POST" class="note-form">

                <div class="form-header">
                    <h1>Edit Note</h1>
                    <p>Update your note details and save changes.</p>
                </div>


                <!-- Title -->
                <div class="form-group">

                    <label for="title">
                        Note Title
                    </label>

                    <input type="text" id="title" name="title" class="form-input" value="<%= note.title %>"
                        placeholder="Enter note title..." required>

                </div>



                <!-- Content -->
                <div class="form-group">

                    <label for="content">
                        Note Content
                    </label>

                    <textarea id="content" name="content" class="form-textarea" placeholder="Write your note here..."
                        rows="8"><%= note.content %></textarea>

                </div>



                <!-- Tags -->

                <div class="form-group">

                    <label for="tags">
                        Tags
                    </label>


                    <input type="text" id="tags" name="tags" class="form-input" value="<%= note.tags.join(', ') %>"
                        placeholder="Example: React, Node, MongoDB">


                    <small class="input-hint">
                        Separate multiple tags using commas
                    </small>

                </div>




                <!-- Pin Note -->

                <div class="pin-option">

                    <input type="checkbox" id="isPinned" name="isPinned" <%=note.isPinned ? "checked" : "" %>
                    >

                    <label for="isPinned">
                        Pin this note
                    </label>

                </div>




                <!-- Actions -->

                <div class="form-actions">

                    <a href="/show" class="btn btn-secondary">
                        Cancel
                    </a>


                    <button type="submit" class="btn btn-primary">
                        Save Changes
                    </button>

                </div>


            </form>

        </section>
</body>

</html>